{
  "name": "task-time-tracker",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm -w packages/web run dev\" \"npm -w packages/server exec -- tsx src/index.ts\"",
    "dev:web": "npm -w packages/web run dev",
    "dev:server": "npm -w packages/server exec -- tsx src/index.ts",
    "build": "npm -w packages/web run build",
    "lint": "npm -w packages/web run lint",
    "preview": "npm -w packages/web run preview"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
